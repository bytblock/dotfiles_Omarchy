# Secrets - never commit these
*.secrets
.env
secrets.sh

# OS files
.DS_Store

# Large binary files (theme backgrounds)
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.bmp

# Claude runtime files
claude/conversations.db
claude/*.db

# Backup files (keep originals, not noise)
*.bak
*.bak.*
*.backup
config/hypr/*.bak.*

# Browser/app data (not config)
config/chromium/
config/vivaldi/
config/mozilla/

# NVM (managed separately)
config/nvm/

# Custom Omarchy themes have their own .git dirs - copy content, not as submodules
# (backup.sh handles copying individual files, excluding .git and images)
config/omarchy/themes/aetheria/.git/
config/omarchy/themes/gold-rush/.git/
config/omarchy/themes/temerald/.git/
