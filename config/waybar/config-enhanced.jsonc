{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 32,
  "margin-top": 6,
  "margin-left": 12,
  "margin-right": 12,
  
  "modules-left": [
    "custom/omarchy", 
    "hyprland/workspaces",
    "custom/separator-left",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/iphone-integration",
    "custom/separator-right",
    "group/tray-expander",
    "bluetooth", 
    "network",
    "pulseaudio",
    "custom/cpu-performance",
    "battery",
    "custom/power"
  ],

  // Left modules
  "custom/omarchy": {
    "format": "<span font='omarchy'>\ue900</span>",
    "on-click": "omarchy-menu",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "â—‹",
      "1": "َ°² ", "2": "َ°²¢", "3": "َ°²¤", "4": "َ°²¦", "5": "َ°²¨",
      "6": "َ°²ھ", "7": "َ°²¬", "8": "َ°²®", "9": "َ°²°", "10": "َ°؟¬",
      "active": "â—ڈ"
    },
    "persistent-workspaces": {
      "1": [], "2": [], "3": [], "4": [], "5": []
    }
  },

  "hyprland/window": {
    "format": "{}",
    "separate-outputs": true,
    "max-length": 40,
    "rewrite": {
      "(.*) â€” Mozilla Firefox": "ًںŒگ $1",
      "(.*) - Visual Studio Code": "ًں’» $1", 
      "(.*) - Cursor": "ًں’» $1",
      "LocalSend": "ًں“± LocalSend",
      "(.*) - Kitty": "ًں“؛ Terminal",
      "(.*)": "$1"
    }
  },

  // Center
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%A, %B %d}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#5AC8FA'><b>{}</b></span>",
        "days": "<span color='#F0F0F0'><b>{}</b></span>",
        "weeks": "<span color='#007AFF'><b>W{}</b></span>",
        "weekdays": "<span color='#FF9500'><b>{}</b></span>",
        "today": "<span color='#30D158'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select"
    }
  },

  // Right modules - Enhanced
  "custom/iphone-integration": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/iphone-status-waybar.sh",
    "interval": 15,
    "return-type": "json",
    "tooltip": true,
    "on-click": "iphone-dashboard"
  },

  "custom/cpu-performance": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/cpu-performance.sh",
    "interval": 10,
    "return-type": "json",
    "tooltip": true,
    "on-click": "cpu-status"
  },

  "network": {
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "َ°€‚",
    "format-disconnected": "َ°¤®",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-ethernet": "â‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "on-click": "omarchy-launch-wifi"
  },

  "bluetooth": {
    "format": "",
    "format-disabled": "َ°‚²",
    "format-connected": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "blueberry"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "$TERMINAL --class=Wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "scroll-step": 5,
    "tooltip-format": "Volume: {volume}%"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-full": "َ°پ¹ {capacity}%",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip-format": "Battery: {capacity}%\nTime: {time}",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "on-click": "cpu-status"
  },

  // Utility modules
  "custom/power": {
    "format": "َ°گ¥",
    "tooltip": "Power Menu",
    "on-click": "~/.config/waybar/scripts/power-menu-waybar.sh"
  },

  "custom/separator-left": {
    "format": "â”‚",
    "tooltip": false
  },

  "custom/separator-right": {
    "format": "â”‚", 
    "tooltip": false
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/expand-icon": {
    "format": "",
    "tooltip": false
  },

  "tray": {
    "icon-size": 14,
    "spacing": 8
  }
}